FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HERMES_HOME=/opt/data

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    cryptsetup-bin \
    curl \
    dmsetup \
    e2fsprogs \
    git \
    ripgrep \
    util-linux \
 && rm -rf /var/lib/apt/lists/*

COPY . /opt/hermes
WORKDIR /opt/hermes

# Install core + dashboard + tinfoil deps for Enclava deployment
RUN pip install --no-cache-dir ".[dashboard]" tinfoil

RUN chmod +x /opt/hermes/docker/entrypoint.sh \
 && chmod +x /opt/hermes/docker/entrypoint-enclava-api.sh

HEALTHCHECK --interval=30s --timeout=5s --start-period=180s --retries=3 \
    CMD curl -f http://localhost:${API_SERVER_PORT:-8000}/health || exit 1

VOLUME ["/opt/data"]
ENTRYPOINT ["/opt/hermes/docker/entrypoint-enclava-api.sh"]
